---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection';
import Marquee from '../components/Marquee';
import AboutSection from '../components/AboutSection';
import ServicesSection from '../components/ServicesSection';
import ProjectsSection, { type ProjectItem } from '../components/ProjectsSection';
import BlogSection, { type BlogSeriesProp } from '../components/BlogSection';
import ContactSection from '../components/ContactSection';
import { loadPublishedPosts, groupPosts } from '../lib/blog';
import { loadPublishedProjects } from '../data/projects';

const posts = await loadPublishedPosts();
const { series } = groupPosts(posts);

const MAX_SERIES_ON_HOME = 4;
const MAX_PROJECTS_ON_HOME = 4;

const blogSeries: BlogSeriesProp[] = series
  .slice(0, MAX_SERIES_ON_HOME)
  .map((group, i) => ({
    number: String(i + 1).padStart(2, '0'),
    slug: group.slug,
    name: group.meta.name,
    description: group.meta.description || group.posts[0].data.description,
    category: group.meta.category,
    href: group.firstPostHref,
    episodes: group.posts.map((p) => ({
      title: p.data.title,
      href: `/blog/${p.id}`,
    })),
  }));

const allProjects = await loadPublishedProjects();
const homeProjects: ProjectItem[] = allProjects
  .slice(0, MAX_PROJECTS_ON_HOME)
  .map((p) => ({
    number: String(p.data.order).padStart(2, '0'),
    category: p.data.category,
    title: p.data.title,
    description: p.data.description,
    stack: p.data.badges.slice(0, 5),
    link: { label: 'View Details', href: `/projects/${p.id}` },
  }));
---

<Layout
  title="JJ.Dev — Unreal Engine Developer"
  description="An unreal engine developer working on simulations, games, and AI-native workflows."
>
  <HeroSection client:load />
  <Marquee client:load />
  <AboutSection client:load />
  <ServicesSection client:load />
  <ProjectsSection client:load projects={homeProjects} />
  <BlogSection client:load series={blogSeries} />
  <ContactSection client:load />
</Layout>
