---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { formatDate } from '../../../lib/blog';
import { getSeriesMeta, SERIES_META } from '../../../data/series';

export async function getStaticPaths() {
  const posts = await getCollection(
    'blog',
    ({ data }) => !data.draft && !!data.series
  );

  const slugSet = new Set<string>(posts.map((p) => p.data.series!));

  return Array.from(slugSet).map((slug) => {
    const seriesPosts = posts
      .filter((p) => p.data.series === slug)
      .sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0));
    return {
      params: { seriesSlug: slug },
      props: { slug, posts: seriesPosts },
    };
  });
}

interface Props {
  slug: string;
  posts: CollectionEntry<'blog'>[];
}

const { slug, posts } = Astro.props;
const meta = getSeriesMeta(slug);
const registered = slug in SERIES_META;
---

<Layout
  title={`${meta.name} — JJ.Dev`}
  description={meta.description || `${meta.name} 시리즈`}
>
  <section class="relative w-full px-6 md:px-12 lg:px-24 py-16 md:py-24">
    <div class="w-full max-w-5xl mx-auto">

      <a
        href="/blog"
        class="group inline-flex items-center gap-3 text-[#9aa5af] uppercase tracking-wider hover:text-[#D7E2EA] transition-colors duration-200 mb-12 md:mb-16"
        style="font-size: clamp(0.8125rem, 0.95vw, 0.9375rem);"
      >
        <span
          aria-hidden="true"
          class="transition-transform duration-200 group-hover:-translate-x-1"
        >←</span>
        Back to Blog
      </a>

      <p class="text-[#646973] uppercase tracking-[0.3em] text-xs md:text-sm mb-5 md:mb-7">
        / Series {registered ? `· ${meta.category}` : ''}
      </p>

      <h1
        class="font-light tracking-tight text-[#D7E2EA] leading-[1.05] mb-6 md:mb-8"
        style="font-size: clamp(2rem, 5vw, 4rem);"
      >
        {meta.name}
      </h1>

      {meta.description && (
        <p
          class="text-[#9aa5af] font-light leading-relaxed max-w-2xl mb-14 md:mb-20"
          style="font-size: clamp(1rem, 1.2vw, 1.25rem);"
        >
          {meta.description}
        </p>
      )}

      <ol class="flex flex-col gap-4 md:gap-5">
        {posts.map((post, i) => (
          <li>
            <a
              href={`/blog/${post.id}`}
              class="group block bg-[#141414] border border-[#1f1f1f] rounded-2xl p-5 md:p-7 hover:border-[#2a2a2a] hover:bg-[#181818] transition-all duration-300"
            >
              <div class="flex items-start gap-4 md:gap-6">
                <span
                  class="text-[#646973] font-light tabular-nums shrink-0 pt-1"
                  style="font-size: clamp(0.875rem, 1.05vw, 1rem);"
                >
                  #{post.data.seriesPart ?? i + 1}
                </span>
                <div class="flex-1 min-w-0">
                  <h3
                    class="text-[#D7E2EA] font-light leading-snug mb-2 group-hover:translate-x-1 transition-transform duration-200"
                    style="font-size: clamp(1.0625rem, 1.4vw, 1.375rem);"
                  >
                    {post.data.title}
                  </h3>
                  <p
                    class="text-[#9aa5af] font-light leading-relaxed mb-3"
                    style="font-size: clamp(0.875rem, 1vw, 1rem);"
                  >
                    {post.data.description}
                  </p>
                  <time
                    datetime={post.data.date.toISOString()}
                    class="text-[#646973] font-light tabular-nums uppercase tracking-[0.2em]"
                    style="font-size: clamp(0.6875rem, 0.8vw, 0.8125rem);"
                  >
                    {formatDate(post.data.date)}
                  </time>
                </div>
                <span
                  aria-hidden="true"
                  class="text-[#646973] shrink-0 pt-2 group-hover:text-[#D7E2EA] group-hover:translate-x-1 transition-all duration-200"
                >
                  →
                </span>
              </div>
            </a>
          </li>
        ))}
      </ol>

      <div class="mt-14 md:mt-20 flex justify-between items-center">
        <a
          href="/blog"
          class="group inline-flex items-center gap-3 text-[#D7E2EA] uppercase tracking-wider hover:opacity-70 transition-opacity duration-200"
          style="font-size: clamp(0.875rem, 1.05vw, 1rem);"
        >
          <span
            aria-hidden="true"
            class="transition-transform duration-200 group-hover:-translate-x-1"
          >←</span>
          Back to Blog
        </a>
        <span class="text-[#646973] uppercase tracking-[0.3em] text-[10px] md:text-xs tabular-nums">
          {posts.length} {posts.length === 1 ? 'post' : 'posts'}
        </span>
      </div>
    </div>
  </section>
</Layout>
